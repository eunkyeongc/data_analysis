   "source": [
    "import csv\n",
    "with open('cctv_2025_dalseo.csv', 'rt') as f:\n",
    "    buffer = csv.reader(f, delimiter=',')\n",
    "\n",
    "    total_cctv = 0 # cctv 갯수를 담을 변수를 0으로 초기화\n",
    "    for i, line in enumerate(buffer):\n",
    "        if i != 0 :\n",
    "            total_cctv += int(line[6])\n",
    "total_cctv\n"
   ]
